      "char": "mousifer",
      "dlg": {
        "text": "One late-summer day at the Academy, as a cool breeze whispers over a quiet campus waiting for its very first students, a reluctant cat arrives.",
        "speaker": null, "style": "narrator", "pos": "bottom"
      },
      "type": "standard", "next": "e1s1b"
    },
    "e1s1b": {
      "bg": "campusmap",
      "char": "mousifer",
      "dlg": {
        "text": "Its ears seem to droop, like it's either tired or sad.",
        "speaker": null, "style": "narrator", "pos": "bottom"
      },
      "type": "choice",
      "choices": [ { "text": "Call out, \"Hello there!\"", "to": "e1s2" } ]
    },
    "e1s2": {
      "bg": "campusmap",
      "char": "mousifer",
      "dlg": {
        "text": "The reluctant cat looks up as it hears you, but its reply is too quiet to make out.",
        "speaker": null, "style": "narrator", "pos": "bottom"
      },
      "type": "choice",
      "choices": [ { "text": "Ask the cat about itself", "to": "e1s3a" } ]
    },
    "e1s3a": {
      "bg": "campusmap",
      "char": "mousifer",
      "dlg": {
        "text": "Oh, hi. I'm, um, just wandering {around a little} ....",
        "speaker": "Reluctant Cat", "style": "mousifer", "pos": "bottom"
      },
      "type": "standard", "next": "e1s3b"
    },
    "e1s3b": {
      "bg": "campusmap",
      "char": "mousifer",
      "dlg": {
        "text": "The cat gets so quiet you can hardly hear it. It appears to be very, very shy. If you could help it feel comfortable, maybe it would open up and talk to you.",
        "speaker": null, "style": "narrator", "pos": "bottom"
      },
      "type": "choice",
      "choices": [ { "text": "Try playing a game with the cat", "to": "e1s4" } ]
    },
    "e1s4": {
      "bg": "campusmap",
      "char": "mousifer",
      "dlg": {
        "text": "Your eyes sparkle with an idea: a game! Everyone likes games. Maybe it'll help the reluctant cat.",
        "speaker": null, "style": "narrator", "pos": "bottom"
      },
      "type": "choice",
      "choices": [ { "text": "Go to Game", "to": "e1end" } ]
    },
